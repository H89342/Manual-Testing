  "item": [
    {
      "name": "Phase 1 — Device Connection",
      "item": [
        {
          "name": "API-001: Verify validating registered IMEI returns 200 with connected status",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set auth token from environment",
                  "const token = pm.environment.get('access_token');",
                  "pm.request.headers.add({ key: 'Authorization', value: 'Bearer ' + token });",
                  "",
                  "// Clear stale chained variables",
                  "pm.environment.unset('response_device_id');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status code",
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 2. Response body fields",
                  "pm.test('Response body contains expected fields', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('device_id');",
                  "    pm.expect(json.status).to.eql(\"connected\");",
                  "    pm.expect(json.imei).to.eql(\"860211234567890\");",
                  "});",
                  "",
                  "// 3. Sensitive fields must be absent",
                  "pm.test('No sensitive fields exposed', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property('secret_key');",
                  "    pm.expect(json).to.not.have.property('internal_token');",
                  "});",
                  "",
                  "// 4. Response time",
                  "pm.test('Response time is under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "// 5. Save values for chaining",
                  "pm.test('Save chained values to environment', function () {",
                  "    const json = pm.response.json();",
                  "    pm.environment.set('response_device_id', json.device_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
